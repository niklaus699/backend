# Django
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=replace-me-with-a-generated-secret
DEBUG=False
ALLOWED_HOSTS=api.sentinel.example.com,localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://sentinel:change-me@localhost:5432/sentinel
CONN_MAX_AGE=600
DB_SSLMODE=require

# Redis / Celery / Channels
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_RESULT_EXPIRES=3600
INGEST_SCHEDULE_HOUR=*/6
INGEST_SCHEDULE_MINUTE=0
SNAPSHOT_SCHEDULE_MINUTE=5

# Frontend / CORS / CSRF
CORS_ALLOWED_ORIGINS=https://app.sentinel.example.com
CSRF_TRUSTED_ORIGINS=https://app.sentinel.example.com
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Email
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=replace-me
DEFAULT_FROM_EMAIL=noreply@sentinel.example.com

# Logging / observability
LOG_LEVEL=INFO
LOG_FILE=/var/log/sentinel/django.log
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Throttling
THROTTLE_ANON_RATE=100/hour
THROTTLE_USER_RATE=1000/hour
THROTTLE_LOGIN_RATE=5/minute
THROTTLE_DISCOVERY_RATE=10/hour
THROTTLE_INGESTION_RATE=60/hour
